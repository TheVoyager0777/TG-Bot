[Unit]
Description=Phantom Telegram control bot
After=network-online.target
Wants=network-online.target
Wants=phantom-console.service phantom-llm.service
After=phantom-console.service phantom-llm.service
ConditionPathExists=/home/voyager/桌面/Workspace/PhantomControlPlane/modules/tg-claude-bot/config.toml
StartLimitIntervalSec=60
StartLimitBurst=3

[Service]
Type=simple
WorkingDirectory=/home/voyager/桌面/Workspace/PhantomControlPlane
# nvm 装的 claude/node 不在默认 PATH，显式加上
Environment=PATH=/home/voyager/.nvm/versions/node/v24.15.0/bin:/usr/local/bin:/usr/bin:/bin
Environment=PYTHONPATH=/home/voyager/桌面/Workspace/PhantomControlPlane/modules/tg-claude-bot:/home/voyager/桌面/Workspace/PhantomControlPlane/modules/phantom-console:/home/voyager/桌面/Workspace/PhantomControlPlane/LLM_Frontend:/home/voyager/桌面/Workspace/PhantomControlPlane/LLM_Backend:/home/voyager/桌面/Workspace/PhantomControlPlane/modules/infiniproxy
Environment=PHANTOM_CONSOLE_EXTERNAL=1
ExecStart=/usr/bin/python3 /home/voyager/桌面/Workspace/PhantomControlPlane/modules/tg-claude-bot/bot.py /home/voyager/桌面/Workspace/PhantomControlPlane/modules/tg-claude-bot/config.toml
Restart=on-failure
RestartSec=5

[Install]
WantedBy=default.target
